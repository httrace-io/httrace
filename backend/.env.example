# Copy this to .env and fill in real values
# NEVER commit .env to git

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# App
ENV=production          # development | production
CORS_ORIGINS=https://traceto.io,https://app.traceto.io
DATABASE_URL=postgresql://user:pass@host/traceto  # switch from SQLite for production

# Admin — required for /v1/billing/provision-key (called by Stripe post-checkout webhook)
PROVISION_SECRET=changeme_use_a_strong_random_secret
